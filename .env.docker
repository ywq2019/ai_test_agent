# ── 应用信息 ─────────────────────────────────────────────────────────────
APP_NAME=AI 测试工具平台
APP_VERSION=1.0.0

# ── 服务配置 ─────────────────────────────────────────────────────────────
DEBUG=False
HOST=0.0.0.0
PORT=4000
CORS_ORIGINS=["*"]

# ── 数据库（路径由 docker-compose.yml 覆盖，此处为兜底值）────────────────
DATABASE_URL=sqlite+aiosqlite:////data/uitest_agent.db

# ── AI 大模型配置 ────────────────────────────────────────────────────────
# 部署完成后可在平台「大模型配置」页直接修改，无需重启
# API URL 不要加 /v1，代码自动拼接
AI_API_KEY=your_api_key_here
AI_API_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash
AI_MODEL_NAME=DeepSeek V4 Flash
AI_TEMPERATURE=0.5

# ── 浏览器 ───────────────────────────────────────────────────────────────
PLAYWRIGHT_BROWSERS=["chromium"]
DEFAULT_BROWSER=chromium

# ── 数据目录（容器内路径，与 Volume 挂载一致）────────────────────────────
REPORT_OUTPUT_DIR=/data/reports
SCREENSHOT_DIR=/data/screenshots
LOG_DIR=/data/logs
UPLOAD_DIR=/data/uploads
