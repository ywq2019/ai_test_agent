# ── 应用信息 ─────────────────────────────────────────────────────────────
APP_NAME=AI 测试工具平台
APP_VERSION=1.0.0

# ── 服务配置 ─────────────────────────────────────────────────────────────
DEBUG=False
HOST=0.0.0.0
PORT=4000
CORS_ORIGINS=["*"]

# ── 安全配置（生产必改！） ────────────────────────────────────────────────
# 生成命令：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-python-secrets-token-hex-32

# 初始管理员账号（首次启动自动创建，建议部署后在「用户管理」页立即修改密码）
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=admin123

# ── 数据库（db 服务和 app 服务共用这三个变量，改一处全部生效）──────────
# 修改密码时，POSTGRES_PASSWORD 和 DATABASE_URL 里的密码必须保持一致
POSTGRES_DB=uitest
POSTGRES_USER=uitest
POSTGRES_PASSWORD=uitest123456
DATABASE_URL=postgresql+asyncpg://uitest:uitest123456@db:5432/uitest

# ── AI 大模型配置 ────────────────────────────────────────────────────────
# 部署完成后可在平台「大模型配置」页直接修改，无需重启
# API URL 不要加 /v1，代码自动拼接
AI_API_KEY=your_api_key_here
AI_API_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash
AI_MODEL_NAME=DeepSeek V4 Flash
AI_TEMPERATURE=0.5

# ── 浏览器 ───────────────────────────────────────────────────────────────
PLAYWRIGHT_BROWSERS=["chromium"]
DEFAULT_BROWSER=chromium

# ── 数据目录（容器内路径，与 Volume 挂载一致）────────────────────────────
REPORT_OUTPUT_DIR=/data/reports
SCREENSHOT_DIR=/data/screenshots
LOG_DIR=/data/logs
UPLOAD_DIR=/data/uploads
AI_CASES_DIR=/data/ai_cases
